# Spark and local data directories
# Ignore generated checkpoints and data files (keep raw folder structure via gitkeeps if necessary)
data/checkpoints/*
!data/checkpoints/.gitkeep
data/raw/*
!data/raw/.gitkeep
data/curated/*
!data/curated/.gitkeep
data/rejects/*
!data/rejects/.gitkeep

# System files
.DS_Store
Thumbs.db

# Devenv
.devenv*
devenv.local.nix
devenv.local.yaml

# direnv
.direnv

# pre-commit
.pre-commit-config.yaml

# Log files
logs/*
logs/**/*.log
!logs/.gitkeep

